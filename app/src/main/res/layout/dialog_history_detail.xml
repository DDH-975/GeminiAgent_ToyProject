<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- 헤더 아이콘 & 타이틀 -->
        <View
            android:id="@+id/view_icon_bg"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_light_blue"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_detail_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_sort_alphabetically"
            app:layout_constraintBottom_toBottomOf="@+id/view_icon_bg"
            app:layout_constraintEnd_toEndOf="@+id/view_icon_bg"
            app:layout_constraintStart_toStartOf="@+id/view_icon_bg"
            app:layout_constraintTop_toTopOf="@+id/view_icon_bg"
            app:tint="@color/operator_sky_blue" />

        <TextView
            android:id="@+id/tv_detail_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/jua"
            android:text="학점 상세 내역"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/view_icon_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/view_icon_bg"
            app:layout_constraintTop_toTopOf="@+id/view_icon_bg" />

        <!-- 본문 리포트 영역 -->
        <ScrollView
            android:id="@+id/scroll_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_detail_content"
            android:maxHeight="250dp"
            android:minHeight="100dp"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@+id/view_icon_bg">

            <TextView
                android:id="@+id/tv_detail_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/expression_text"
                android:textSize="15sp"
                tools:text="- 국어: A+ (3학점)\n- 수학: B+ (3학점)\n- 영어: A0 (2학점)" />
        </ScrollView>

        <!-- 결과 영역 (포인트 배지 스타일) -->
        <LinearLayout
            android:id="@+id/layout_result_badge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_detail_content"
            android:backgroundTint="#F0F7FF"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@+id/scroll_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="최종 결과"
                android:textColor="@color/expression_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_detail_result"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/operator_sky_blue"
                android:textSize="30dp"
                android:textStyle="bold"
                tools:text="4.50" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_close_detail"
            style="@style/ActionButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="확인"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@+id/layout_result_badge" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>